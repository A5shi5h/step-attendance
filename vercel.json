{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/backend",
      "entrypoint": "server.js"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
       {
  "key": "Content-Security-Policy",
  "value": "frame-ancestors *"
}
      ]
    }
  ]
}
